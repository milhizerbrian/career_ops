PREFER_CLAUDE_SYNTHESIS=0
CLAUDE_SYNTHESIS_MODEL=claude-sonnet-4-6
CLAUDE_POLISH_MODEL=claude-sonnet-4-6
LM_STUDIO_ANALYSIS_MODEL=qwen2.5-coder-7b-instruct-mlx
# Resume synthesis model (LM Studio first-pass). Default matches the analysis
# model (above) so both pre-flight gap analysis and synthesis share one loaded
# model — eliminates a second load/unload cycle. Downgraded from 14B → 7B
# because the LM Studio output is an intermediate JSON draft that Claude
# rewrites in pass 2; 7B is sufficient and roughly halves RAM (~9 GB → ~4.5 GB)
# and inference time.
LM_STUDIO_SYNTHESIS_MODEL=qwen2.5-coder-7b-instruct-mlx

# Idle timeout (ms) before LM Studio model auto-unloads. Default 10 minutes —
# keeps the model resident across rapid-fire generations, frees RAM after idle.
LM_STUDIO_IDLE_UNLOAD_MS=600000

RESUME_DOCX_TEMPLATE_PATH=
# DOCX is the primary/final resume artifact. Set to 1 only when local
# LibreOffice/pdfinfo PDF export and page-count feedback are desired.
RESUME_PDF_EXPORT=0
# Optional explicit LibreOffice/soffice path for PDF export.
RESUME_SOFFICE_PATH=
ANTHROPIC_API_KEY=your_key_here
PORT=3000

# Test/CI path overrides. Leave empty for normal local use.
CAREER_OPS_DATA_DIR=
CAREER_OPS_CONFIG_DIR=
CAREER_OPS_TRACKER_PATH=
CAREER_OPS_GMAIL_JOBS_PATH=
CAREER_OPS_DISABLE_LM_STUDIO=0
CAREER_OPS_HEALTH_NON_SECRET=0

# Gmail sync (gmail-sync.mjs / npm run gmail-sync)
# Setup: run `node oauth-setup.mjs` once to generate GMAIL_REFRESH_TOKEN
# Google Cloud Console → Gmail API → OAuth2 client (Desktop app type)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
